zk-location-float/output/
zk-location-float/audio/**/output/

# Node.js
**/node_modules/

# Python
**/__pycache__/
*.pyc
*.pyo
hyperveritas-audio/hyperveritas_impl/hyperveritas/

# CMake / C++ builds
**/build/
**/build_prover/

