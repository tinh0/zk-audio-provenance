{
  "manifest_version": 3,
  "name": "HyperVerITAS Provenance Verifier",
  "version": "0.1",
  "description": "Verifies zero-knowledge provenance proofs on audio and images across the web.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HyperVerITAS Verifier"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "http://127.0.0.1:*/*", "file:///*"],
      "js": ["content.js"],
      "css": ["badge.css"],
      "run_at": "document_idle"
    }
  ]
}
